{
  extends: [
    'config:recommended',
  ],
  labels: [
    'automation',
  ],
  enabledManagers: [
    'custom.regex',
  ],
  packageRules: [
    {
      matchManagers: [
        'custom.regex',
      ],
      groupName: 'otelcol',
    },
  ],
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/distributions/elastic-components/manifest.yaml$/',
      ],
      datasourceTemplate: 'go',
      matchStrings: [
        'gomod: (?<depName>.+) (?<currentValue>.+)',
      ],
    },
  ],
}
